rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザー認証チェック
    function isAuthenticated() {
      return request.auth != null;
    }

    // ホワイトリスト登録済みユーザーかチェック
    function isWhitelisted() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 管理者かチェック
    function isAdmin() {
      return isWhitelisted() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 集計所属変更メンテナンスゲート(ADR-0019、GOAL.md タスクG)
    // Cloud Functions(OCR確定/split/顧客マスター同期)はAdmin SDK経由でルール適用外のため
    // コード側(functions/src/utils/maintenanceGate.ts)でゲートするが、FEからのクライアント
    // SDK直接書込み(useDocumentEdit.ts等)はルール側でもゲートする必要がある。
    // フラグドキュメントが存在しない場合は安全側デフォルトとして「開いている」扱いにする
    // (functions/src/utils/maintenanceGate.ts の isGroupAggregationGateOpen() と同一の既定値)。
    function groupAggregationGateOpen() {
      // フラグdocは存在するがgroupAggregationGateOpenフィールド自体が未設定のケースを
      // 明示的に許可側へ倒す。Firestore Rulesは存在しないフィールドへの`.`アクセスで
      // 評価エラー(deny)になるため、`in`演算子での存在チェックが必須
      // (実機検証で確認: 未対応時「Property groupAggregationGateOpen is undefined on
      // object」エラーにより安全側デフォルトの意図に反し更新拒否側に倒れることを確認済み)。
      return !exists(/databases/$(database)/documents/system/maintenanceFlags) ||
        !('groupAggregationGateOpen' in get(/databases/$(database)/documents/system/maintenanceFlags).data) ||
        get(/databases/$(database)/documents/system/maintenanceFlags).data.groupAggregationGateOpen != false;
    }

    // documentGroupsの集計所属に影響しうるフィールドのいずれかが変更される更新かどうか
    // (ADR-0019のゲート対象と同一)。表示名フィールド(customerName等)だけでなく、実際に
    // 集計キーとして使われる正規化フィールド(customerKey等)とstatusも含める(/codex review
    // P1/P2指摘、comment-analyzer指摘: useDocumentEdit.tsのeditedFields.careManagerKeyの
    // ようにKeyフィールドをNameと独立に書き込める経路が型上reachableであり、Nameのみの
    // チェックではゲートを迂回できてしまう。statusも'split'遷移でgetAffectedGroups()が
    // 全グループから除外判定するため対象に含める)。
    function affectsGroupAggregationFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'customerName', 'officeName', 'documentType', 'careManager',
        'customerKey', 'officeKey', 'documentTypeKey', 'careManagerKey',
        'status'
      ]);
    }

    // ドキュメント（書類管理）
    match /documents/{docId} {
      allow read: if isWhitelisted();
      // 作成: Cloud Functionsのみ（サービスアカウント経由、ルール適用外）
      allow create: if false;
      // 更新: 許可されたフィールドのみ
      allow update: if isWhitelisted()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          // 顧客解決フィールド（Phase 7）
          'customerId',
          'customerName',
          'customerKey',
          'customerConfirmed',
          'needsManualCustomerSelection',
          'confirmedBy',
          'confirmedAt',
          'isDuplicateCustomer',
          // 事業所解決フィールド
          'officeId',
          'officeName',
          'officeKey',
          'officeConfirmed',
          'officeConfirmedBy',
          'officeConfirmedAt',
          // OCR結果編集フィールド
          'displayFileName',
          'documentType',
          'documentTypeKey',
          'documentTypeConfirmed',
          'careManagerKey',
          'fileDate',
          'fileName',
          'editedBy',
          'editedAt',
          'updatedAt',
          // OCR結果確認ステータスフィールド
          'verified',
          'verifiedBy',
          'verifiedAt',
          // 再処理用フィールド（getReprocessClearFields対応）
          'status',
          'ocrResult',
          'ocrResultUrl',
          'summary',
          'summaryTruncated',
          'summaryOriginalLength',
          'ocrExtraction',
          'pageResults',
          'fileDateFormatted',
          'careManager',
          'category',
          'customerCandidates',
          'officeCandidates',
          'extractionScores',
          'extractionDetails',
          'allCustomerCandidates',
          'suggestedNewOffice',
          'provenance',
          'error',
          'lastErrorMessage',
          'lastErrorId',
          'retryCount',
          'retryAfter',
          'errorRescueCount',
          'lastRescuedAt',
          // ADR-0018 (Issue #547): detail/main サブコレクション分離に伴う軽量抜粋フィールド
          'ocrExcerpt'
        ])
        // confirmedBy は自分のUIDのみ設定可能（事業所解決時は含まれない場合あり）
        && (request.resource.data.confirmedBy == request.auth.uid
            || request.resource.data.confirmedBy == resource.data.confirmedBy
            || request.resource.data.confirmedBy == null
            || !('confirmedBy' in request.resource.data))
        // officeConfirmedBy は自分のUIDのみ設定可能
        && (request.resource.data.officeConfirmedBy == request.auth.uid
            || request.resource.data.officeConfirmedBy == resource.data.officeConfirmedBy
            || request.resource.data.officeConfirmedBy == null
            || !('officeConfirmedBy' in request.resource.data))
        // editedBy は自分のUIDのみ設定可能
        && (request.resource.data.editedBy == request.auth.uid
            || request.resource.data.editedBy == resource.data.editedBy
            || request.resource.data.editedBy == null
            || !('editedBy' in request.resource.data))
        // verifiedBy は自分のUIDのみ設定可能
        && (request.resource.data.verifiedBy == request.auth.uid
            || request.resource.data.verifiedBy == resource.data.verifiedBy
            || request.resource.data.verifiedBy == null
            || !('verifiedBy' in request.resource.data))
        // サーバー専有フィールド (Codex review #569 P2反映、2nd round P2でnull挿入脆弱性を修正):
        // FEは getReprocessClearFields() 経由の deleteField() でのみこれらを操作する
        // (frontend/src/hooks/useDocuments.ts に値を設定する経路は存在しない)。値の新規
        // 設定・上書きを許可すると、retryAfter を未来日時に書き換えて再処理を永久にスキップ
        // させたり、provenance を改ざんして rotatePdfPages の整合性検証を無効化する等の
        // 悪用経路になるため、削除(フィールド不在への遷移)または無変更のみ許可する。
        // `('field' in resource.data)` の明示チェックが必須: これが無いと、フィールド不在の
        // docに対して `field: null` を新規注入しても resource.data.get(field, null)==null と
        // 一致してしまい、「フィールドが存在するが値がnull」という不正状態を作れてしまう
        // (Phase C backfillのpresence判定やrotatePdfPagesのlegacy provenance guardを誤動作させる)。
        && (!('retryCount' in request.resource.data)
            || (('retryCount' in resource.data) && request.resource.data.retryCount == resource.data.retryCount))
        && (!('retryAfter' in request.resource.data)
            || (('retryAfter' in resource.data) && request.resource.data.retryAfter == resource.data.retryAfter))
        && (!('errorRescueCount' in request.resource.data)
            || (('errorRescueCount' in resource.data) && request.resource.data.errorRescueCount == resource.data.errorRescueCount))
        && (!('lastRescuedAt' in request.resource.data)
            || (('lastRescuedAt' in resource.data) && request.resource.data.lastRescuedAt == resource.data.lastRescuedAt))
        && (!('provenance' in request.resource.data)
            || (('provenance' in resource.data) && request.resource.data.provenance == resource.data.provenance))
        // ADR-0018 (Issue #547): ocrExcerptもFunctions(ocrProcessor.ts)専有の派生フィールド。
        // FEはgetReprocessClearFields()のdeleteField()でのみ操作する想定(#9参照)。
        && (!('ocrExcerpt' in request.resource.data)
            || (('ocrExcerpt' in resource.data) && request.resource.data.ocrExcerpt == resource.data.ocrExcerpt))
        // ADR-0019 (GOAL.md タスクG): 集計所属変更メンテナンスゲートが閉じている間は、
        // customer/office/documentType/careManagerを変更するクライアント直接書込み
        // (useDocumentEdit.ts等)を拒否する。Cloud Functions(Admin SDK経由)はルール適用外の
        // ため、この制約はFE経由の書込みにのみ効く(Cloud Functions側は
        // functions/src/utils/maintenanceGate.ts でコードレベルにゲート済み)。
        && (!affectsGroupAggregationFields() || groupAggregationGateOpen());
      allow delete: if isAdmin();
    }

    // ADR-0018 (Issue #547): OCR結果本文のサブコレクション分離 (Firestore egress削減)
    // Phase B (dual-write) 時点では本体からの読込を継続し、本サブコレクションは
    // Functionsのみが書込む。Phase D以降でFE/Functionsの読込先をこちらへ切替える。
    match /documents/{docId}/detail/{detailId} {
      allow read: if isWhitelisted()
        && exists(/databases/$(database)/documents/documents/$(docId));
      // 作成: Cloud Functionsのみ（サービスアカウント経由、ルール適用外）
      allow create: if false;
      // 更新: Functionsが書込んだocrResult/pageResultsをFEが削除する用途のみ許可
      // (Codex review #569 P2反映)。Phase D以降のreprocess-clear(#7)もdeleteField()
      // のみで、値の新規設定・上書きはFunctions専有(ルール適用外のAdmin SDK経由)。
      // ホワイトリスト登録ユーザーによるOCR内容の任意書換えを防ぐため、親の
      // サーバー専有フィールドと同じく削除または無変更のみ許可する。
      allow update: if isWhitelisted()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ocrResult', 'pageResults'])
        && (!('ocrResult' in request.resource.data)
            || (('ocrResult' in resource.data) && request.resource.data.ocrResult == resource.data.ocrResult))
        && (!('pageResults' in request.resource.data)
            || (('pageResults' in resource.data) && request.resource.data.pageResults == resource.data.pageResults));
      allow delete: if isAdmin();
    }

    // 顧客解決監査ログ（Phase 7）
    match /customerResolutionLogs/{logId} {
      allow read: if isWhitelisted();
      // 作成: 認証済みユーザー、必須フィールドチェック
      allow create: if isWhitelisted()
        && request.resource.data.resolvedBy == request.auth.uid
        && request.resource.data.documentId is string
        && request.resource.data.documentId.size() > 0
        // newCustomerIdはstringまたはnull（該当なし選択時）
        && (request.resource.data.newCustomerId == null || request.resource.data.newCustomerId is string)
        && request.resource.data.newCustomerName is string
        && request.resource.data.newCustomerName.size() > 0
        && request.resource.data.resolvedByEmail is string
        && request.resource.data.resolvedAt is timestamp;
      // 更新・削除は禁止（監査ログは不変）
      allow update, delete: if false;
    }

    // 事業所解決監査ログ
    match /officeResolutionLogs/{logId} {
      allow read: if isWhitelisted();
      // 作成: 認証済みユーザー、必須フィールドチェック
      allow create: if isWhitelisted()
        && request.resource.data.resolvedBy == request.auth.uid
        && request.resource.data.documentId is string
        && request.resource.data.documentId.size() > 0
        // newOfficeIdはstringまたはnull（該当なし選択時）
        && (request.resource.data.newOfficeId == null || request.resource.data.newOfficeId is string)
        && request.resource.data.newOfficeName is string
        && request.resource.data.newOfficeName.size() > 0
        && request.resource.data.resolvedByEmail is string;
        // resolvedAtはserverTimestamp()で設定されるため、検証はスキップ
      // 更新・削除は禁止（監査ログは不変）
      allow update, delete: if false;
    }

    // ドキュメント編集監査ログ
    match /editLogs/{logId} {
      allow read: if isWhitelisted();
      // 作成: 認証済みユーザー、必須フィールドチェック
      allow create: if isWhitelisted()
        && request.resource.data.editedBy == request.auth.uid
        && request.resource.data.documentId is string
        && request.resource.data.documentId.size() > 0
        && request.resource.data.fieldName is string
        && request.resource.data.fieldName.size() > 0
        && request.resource.data.editedByEmail is string;
      // 更新・削除は禁止（監査ログは不変）
      allow update, delete: if false;
    }

    // マスターデータ
    match /masters/{masterId}/items/{itemId} {
      allow read: if isWhitelisted();
      allow write: if isAdmin();
    }

    // エラー履歴
    match /errors/{errorId} {
      allow read: if isWhitelisted();
      allow write: if isAdmin();
    }

    // Gmail受信ログ
    match /gmailLogs/{logId} {
      allow read: if isWhitelisted();
      allow write: if false; // Cloud Functionsのみ
    }

    // ユーザー管理
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // 自分自身のドキュメント作成を許可（ドメイン許可リストによる自動登録用）
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // アプリ設定
    match /settings/{settingId} {
      // settings/authは認証済みユーザーなら読める（ドメイン許可チェック用）
      // 新規ドメインユーザーがusersコレクションに未登録の状態でallowedDomainsを確認する必要があるため
      allow read: if settingId == 'auth' && isAuthenticated();
      // その他の設定はホワイトリスト登録済みユーザーのみ
      allow read: if settingId != 'auth' && isWhitelisted();
      allow write: if isAdmin();
    }

    // Phase 8: ドキュメントグループ（サマリー集計）
    match /documentGroups/{groupId} {
      allow read: if isWhitelisted();
      // 書き込みはCloud Functionsのみ（onDocumentWriteトリガー）
      allow write: if false;
    }

    // 集計イベント冪等台帳(Issue #660修正、ADR-0020)。onDocumentWriteが
    // event.idごとの処理済みマーカーを記録する内部専用コレクション。
    // FE/管理者いずれも読み書き不要(Cloud FunctionsはAdmin SDK経由でルール適用外)。
    match /documentAggregationEvents/{eventId} {
      allow read, write: if false;
    }

    // 検索インデックス
    match /search_index/{tokenId} {
      allow read: if isWhitelisted();
      // 書き込みはCloud Functionsのみ（onDocumentWriteSearchIndexトリガー）
      allow write: if false;
    }

    // 検索マイグレーション状態
    match /_migrations/{migrationId} {
      allow read: if isAdmin();
      // 書き込みはCloud Functions/管理スクリプトのみ
      allow write: if false;
    }

    // エイリアス学習履歴
    match /aliasLearningLogs/{logId} {
      allow read: if isWhitelisted();
      // 書き込みはCloud Functions（addMasterAlias）のみ
      allow write: if false;
    }

    // アップロードログ
    match /uploadLogs/{logId} {
      allow read: if isWhitelisted();
      // 書き込みはCloud Functions（uploadPdf）のみ
      allow write: if false;
    }
  }
}
